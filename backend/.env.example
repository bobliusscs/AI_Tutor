# Application Settings
APP_NAME=MindGuide
APP_VERSION=1.0.0
DEBUG=True

# Database Configuration
DATABASE_TYPE=sqlite  # sqlite or mysql
DATABASE_URL=sqlite:///./mindguide.db
# For MySQL: mysql://user:password@localhost:3306/mindguide

# Redis Configuration (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# AI Model Configuration
AI_MODEL_PROVIDER=ollama  # openai, qwen, or ollama
OPENAI_API_KEY=not-needed-for-ollama
OPENAI_MODEL=qwen3.5:9B

# Ollama Configuration (推荐用于本地部署)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9B

# Custom API Configuration (支持通义千问、DeepSeek、智谱AI等)
CURRENT_PROVIDER=ollama  # ollama or custom
CUSTOM_API_KEY=
CUSTOM_API_BASE_URL=https://api.openai.com/v1
CUSTOM_MODEL=gpt-4o-mini
CUSTOM_SUPPORTS_THINKING=false

# Tavily Web Search Configuration (联网搜索功能)
# 获取 API Key: https://app.tavily.com
TAVILY_API_KEY=

# =============================================================================
# DashScope TTS Configuration (阿里云语音合成)
# =============================================================================
# 阿里云百炼 API Key (用于云端语音合成)
# 获取 API Key: https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=

# Qwen Model Configuration (Local)
QWEN_MODEL_PATH=./models/qwen-7b
QWEN_DEVICE=cuda  # cuda or cpu

# JWT Settings
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Settings
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Server Settings
HOST=0.0.0.0
PORT=8000

# =============================================================================
# Prompt 构建配置（参考 OpenClaw 设计）
# =============================================================================

# 是否启用引导文件注入
ENABLE_BOOTSTRAP_FILES=true

# 引导文件最大总字符数
MAX_BOOTSTRAP_TOTAL_CHARS=150000

# 单个引导文件最大字符数
MAX_BOOTSTRAP_FILE_CHARS=20000

# 是否启用 Skills 注入
ENABLE_SKILLS_INJECTION=true

# Skills 提示词最大字符数
MAX_SKILLS_PROMPT_CHARS=15000

# 默认提示词模式 (full/minimal/none)
DEFAULT_PROMPT_MODE=full

# 是否启用安全准则
ENABLE_SAFETY=true

# 是否启用记忆工具说明
ENABLE_MEMORY=true
